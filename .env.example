# =============================================================
# Organizing Life Services AI Operations System
# Environment Variables — COPY THIS TO .env AND FILL IN VALUES
# =============================================================

# ---------- Postgres ----------
POSTGRES_USER=ols_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ols_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------- FastAPI ----------
FASTAPI_ENV=development
FASTAPI_PORT=8000
SECRET_KEY=CHANGE_ME
# Pin browser origins even in examples; add LAN/Tailscale origins explicitly
# only after deciding the access boundary.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UVICORN_RELOAD=true

# ---------- OLS API Authentication ----------
# Required: all endpoints (except /health) need this in the X-API-Key header
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
OLS_API_KEY=CHANGE_ME

# ---------- n8n ----------
N8N_IMAGE=n8nio/n8n:1.97.1
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
# Required for durable n8n credential recovery across rebuilds/restores.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME

# ---------- Backups ----------
# Optional but recommended on the Mac mini. Generate a long passphrase and keep
# it outside this repo/password manager-backed.
BACKUP_ENCRYPTION_PASSWORD=
BACKUP_RETENTION_DAYS=14

# ---------- Google APIs (SEO Integrations) ----------
# Service account JSON key file path (mounted into container)
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-service-account.json

# Google Search Console
GSC_SITE_URL=https://www.organizinglifeservices.com

# Google Analytics 4
GA4_PROPERTY_ID=

# Google Business Profile
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=

# Google Tag Manager
# Run GET /api/seo/gtm/discover to find these (after adding the service-
# account email as a User on the GTM container).
# CONTAINER_ID is the numeric internal ID, NOT the public GTM-XXXX ID.
GTM_ACCOUNT_ID=
GTM_CONTAINER_ID=

# Google Ads
# CUSTOMER_ID = the actual ad account (no dashes, e.g. 5486213910).
# LOGIN_CUSTOMER_ID = the manager (MCC) account ID, only needed if the
#   account is accessed THROUGH a manager. Leave blank for direct access.
# DEVELOPER_TOKEN = apply at https://ads.google.com/aw/apicenter (1-2 days).
# CLIENT_ID / CLIENT_SECRET = OAuth Desktop app from Google Cloud Console.
# REFRESH_TOKEN = generated by `python scripts/get_google_ads_refresh_token.py`.
# When DEVELOPER_TOKEN is empty the system falls back to the GA4-derived
# Ads metrics (no campaign config / conversion-action audits available).
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# ---------- Google Sheets (Operator Dashboard) ----------
GOOGLE_SHEETS_SPREADSHEET_ID=

# ---------- Shopify ----------
SHOPIFY_STORE=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2024-10

# ---------- Anthropic (Claude Vision AI) ----------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-20250514

# ---------- OpenAI / xAI ----------
OPENAI_API_KEY=
XAI_API_KEY=

# ---------- Local LLM (Ollama on Mac mini host) ----------
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL=gemma4:12b
LOCAL_LLM_LARGE_MODEL=gemma4:31b
