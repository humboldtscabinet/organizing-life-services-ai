# =============================================================
# Organizing Life Services AI Operations System
# Environment Variables — COPY THIS TO .env AND FILL IN VALUES
# =============================================================

# ---------- Postgres ----------
POSTGRES_USER=ols_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ols_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------- FastAPI ----------
FASTAPI_ENV=development
FASTAPI_PORT=8000
SECRET_KEY=CHANGE_ME

# ---------- n8n ----------
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME

# ---------- Google APIs (SEO Integrations) ----------
# Service account JSON key file path (mounted into container)
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-service-account.json

# Google Search Console
GSC_SITE_URL=https://www.organizinglifeservices.com

# Google Analytics 4
GA4_PROPERTY_ID=

# Google Business Profile
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=

# Google Ads
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# ---------- Google Sheets (Operator Dashboard) ----------
GOOGLE_SHEETS_SPREADSHEET_ID=

# ---------- Shopify (future phase) ----------
# SHOPIFY_STORE_URL=
# SHOPIFY_ACCESS_TOKEN=

# ---------- AI / LLM (future phase) ----------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
