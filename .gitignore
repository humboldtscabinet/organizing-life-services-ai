# =============================================================
# Organizing Life Services AI — .gitignore
# =============================================================

# ---------- Environment / Secrets ----------
.env
.env.backup-*
credentials/
*.json
!package.json
!package-lock.json
!tsconfig.json

# ---------- Python ----------
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# ---------- Docker ----------
# Don't ignore docker-compose.yml — it's version-controlled
docker-compose.override.yml

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ---------- Postgres data (local volume) ----------
infra/postgres/data/
infra/backup/out/

# ---------- SEO audit raw outputs ----------
# Historical audits are committed for trend analysis.
# (Was previously `data/audit_output/` — un-ignored 2026-05-25.)
data/audit_output/*key*
data/audit_output/*token*
data/audit_output/*secret*

# ---------- n8n local data ----------
n8n_data/

# ---------- Logs ----------
*.log
logs/

# ---------- OS ----------
Thumbs.db
.DS_Store

# ---------- Test / Coverage ----------
.coverage
htmlcov/
.pytest_cache/

# ---------- Session tokens / cookies (never commit) ----------
data/xo_session_token.txt
data/xo_cookies.pkl
data/xo_*.json
data/xo_*.js
data/test.txt
data/*.pkl
data/verify_session*.py
# Narrowed from data/*session* — that glob also matched the tracked
# sessionN_*.py SEO deploy scripts (session5-9). Only ignore session *token* files.
data/*session_token*
data/*token*
data/*cookies*

# ---------- Conversation archive ----------
# Transcript contents are private artifacts, not source code.
conversations/raw/
conversations/markdown/
conversations/private/
conversations/scripts/*.log
# Trigger file for WatchPaths-based manual backup (never commit)
conversations/.trigger

# ---------- Local audit venv ----------
.venv-audit/
# NOTE: data/audit_output/ is intentionally tracked (see top of file).

# ---------- Allow versioned n8n workflows despite *.json rule ----------
!workflows/n8n/*.json

# ---------- Allow versioned SEO audit JSON despite *.json rule ----------
!data/audit_output/*.json
