# =============================================================
# Organizing Life Services AI — .gitignore
# =============================================================

# ---------- Environment / Secrets ----------
.env
credentials/
*.json
!package.json
!tsconfig.json

# ---------- Python ----------
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# ---------- Docker ----------
# Don't ignore docker-compose.yml — it's version-controlled
docker-compose.override.yml

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ---------- Postgres data (local volume) ----------
infra/postgres/data/

# ---------- SEO audit raw outputs ----------
# Historical audits are committed for trend analysis.
# (Was previously `data/audit_output/` — un-ignored 2026-05-25.)

# ---------- n8n local data ----------
n8n_data/

# ---------- Logs ----------
*.log
logs/

# ---------- OS ----------
Thumbs.db
.DS_Store

# ---------- Test / Coverage ----------
.coverage
htmlcov/
.pytest_cache/

# ---------- Session tokens / cookies (never commit) ----------
data/xo_session_token.txt
data/xo_cookies.pkl
data/xo_*.json
data/xo_*.js
data/test.txt
data/*.pkl
data/*session*
data/*token*
data/*cookies*

# ---------- Conversation archive ----------
# Raw transcripts must be gzipped (GitHub rejects files >100MB).
# Block any uncompressed .jsonl from accidentally being committed.
conversations/raw/*.jsonl
conversations/scripts/backup.log
# Trigger file for WatchPaths-based manual backup (never commit)
conversations/.trigger

# ---------- Local audit venv ----------
.venv-audit/
# NOTE: data/audit_output/ is intentionally tracked (see top of file).

# ---------- Allow versioned n8n workflows despite *.json rule ----------
!workflows/n8n/*.json

# ---------- Allow versioned SEO audit JSON despite *.json rule ----------
!data/audit_output/*.json
