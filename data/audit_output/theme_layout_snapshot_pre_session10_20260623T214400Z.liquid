    {"@type": "AdministrativeArea", "name": "Hillsborough County"},
    {"@type": "AdministrativeArea", "name": "Hernando County"},
    {"@type": "AdministrativeArea", "name": "Citrus County"}
  ],
  "sameAs": [
    "https://www.facebook.com/profile.php?id=100063703233651",
